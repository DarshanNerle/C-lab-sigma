rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if a user is an admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Function to check if a user is a teacher
    function isTeacher() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    match /users/{userId} {
      allow read: if request.auth != null; // Anyone can read basic profile info for leaderboards
      allow create: if request.auth != null && request.auth.uid == userId; 
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /notebook_entries/{entryId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /experiment_history/{historyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /league_scores/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /lab_arena_rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.memberIds.hasAny([request.auth.uid]) ||
        request.resource.data.memberIds.hasAny([request.auth.uid])
      );
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    match /lab_arena_invites/{inviteId} {
      allow read: if request.auth != null && (
        resource.data.toUserId == request.auth.uid ||
        resource.data.fromUserId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.fromUserId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.toUserId == request.auth.uid ||
        resource.data.fromUserId == request.auth.uid
      );
      allow delete: if false;
    }
    
    match /chemicals/{chemicalId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /experiments/{experimentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isTeacher();
    }
    
    match /reports/{reportId} {
      allow read: if request.auth != null && (resource.data.studentId == request.auth.uid || isTeacher() || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || isTeacher();
    }

    match /classrooms/{classroomId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isTeacher();
    }

    match /{document=**} {
      // Default denyall catch-all
      allow read, write: if false; 
    }
  }
}
